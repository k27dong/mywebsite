---
const home = { full_name: "kefan.me", short_name: "KD", path: "/" }

const links = [
  { name: "CV", path: "/cv" },
  { name: "Projects", path: "/project" },
  { name: "Articles", path: "/blog" },
  { name: "Book", path: "/book" },
  { name: "Contact", path: "/contact" },
]
---

<nav
  class="main-nav fixed top-0 left-0 z-[100] flex min-h-[var(--nav-height)] w-full items-center
    gap-3.5 border-b border-black bg-[#f0f0f2] pr-[0.7em] sm:gap-4 md:gap-6"
>
  <a
    class="grid aspect-[1/1] h-[var(--nav-height)] place-content-center bg-black px-[1.2rem]
      text-[1rem] leading-[1] font-extrabold text-white no-underline active:translate-y-[1px]
      sm:aspect-[2.618/1] sm:px-[2rem] sm:text-[1.1rem]"
    href={home.path}
  >
    <span class="sm:hidden">{home.short_name}</span>
    <span class="hidden sm:inline">{home.full_name}</span>
  </a>

  {
    links.map((link) => (
      <a
        class="text-[0.9rem] leading-[1] font-medium tracking-tight text-[var(--text-color)]
          uppercase no-underline [text-underline-offset:2px] hover:underline
          active:translate-y-[1px] sm:text-[0.9rem] sm:tracking-normal"
        href={link.path}
      >
        {link.name}
      </a>
    ))
  }
</nav>
