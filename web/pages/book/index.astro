---
import { getCollection, type CollectionEntry } from "astro:content"

import Callout from "@/components/Callout.astro"
import MainLayout from "@/layouts/MainLayout.astro"

type Booknote = CollectionEntry<"booknotes">

const booknotes: Booknote[] = (await getCollection("booknotes")).sort(
  (a: Booknote, b: Booknote) => b.data.id - a.data.id,
)

const total_notes = booknotes.reduce((acc, book) => acc + book.data.notenum, 0)

// Numeric sort key for year_published. Handles digit-only years and a few dynasty names.
const yearSortKey = (y: string): number => {
  const num = parseInt(y, 10)
  if (!isNaN(num)) return num
  const dynasties: Record<string, number> = {
    西汉: -100,
    东汉: 100,
    三国: 230,
    西晋: 270,
    东晋: 360,
    隋朝: 580,
    唐朝: 700,
    五代: 920,
    北宋: 1050,
    南宋: 1200,
    元朝: 1300,
    明朝: 1500,
    清朝: 1750,
    民国: 1930,
  }
  return dynasties[y] ?? 0
}
---

<MainLayout title="Booknotes">
  <Callout slot="callout">{`Total: ${total_notes} entries`} </Callout>

  <section class="mx-auto w-full max-w-screen-xl px-8 pb-12 md:px-10 md:pb-24 lg:px-24">
    <div class="mx-auto max-w-5xl">
      <table class="w-full table-auto border-collapse">
        <thead>
          <tr>
            <th class="w-5/12 px-2 py-2 text-left sm:w-auto sm:px-4">Title</th>
            <th class="w-5/12 px-1 py-2 text-left sm:w-auto sm:px-4">Author</th>
            <th
              data-sort-col="count"
              data-sort-label="Count"
              class="w-1/6 cursor-pointer px-1 py-2 text-center whitespace-nowrap underline-offset-4 hover:underline sm:w-auto sm:px-6"
            >
              <span class="sort-label">Count</span>
            </th>
            <th class="hidden w-[1%] px-6 py-2 text-left whitespace-nowrap md:table-cell">
              Country
            </th>
            <th
              data-sort-col="year"
              data-sort-label="Year"
              class="hidden w-[1%] cursor-pointer px-6 py-2 text-center whitespace-nowrap underline-offset-4 hover:underline md:table-cell"
            >
              <span class="sort-label">Year</span>
            </th>
          </tr>
        </thead>
        <tbody class="font-article border-b border-gray-500">
          {
            booknotes.map((book, index) => (
              <tr
                class={`${index === 0 ? "border-black" : "border-gray-500"} border-t`}
                data-count={book.data.notenum}
                data-year={yearSortKey(book.data.year_published)}
              >
                <td
                  class="w-3/6 overflow-hidden px-2 py-2 text-base overflow-ellipsis sm:w-auto
                    sm:px-4"
                >
                  <a
                    href={`/book/${book.data.title}/`}
                    class="font-medium underline decoration-1 underline-offset-2 hover:decoration-2"
                  >
                    {book.data.title}
                  </a>
                </td>
                <td class="w-2/6 overflow-hidden px-1 py-2 overflow-ellipsis sm:w-auto sm:px-4">
                  {book.data.author}
                </td>
                <td
                  class="font-jbmono w-1/6 px-1 py-2 text-center whitespace-nowrap sm:w-auto
                    sm:px-6"
                >
                  {book.data.notenum}
                </td>
                <td class="hidden w-[1%] px-6 py-2 whitespace-nowrap md:table-cell">
                  {book.data.country}
                </td>
                <td
                  class:list={[
                    "hidden w-[1%] px-6 py-2 text-center whitespace-nowrap md:table-cell",
                    /[一-龥]/.test(book.data.year_published)
                      ? "font-sourcehan"
                      : "font-jbmono",
                  ]}
                >
                  {book.data.year_published}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</MainLayout>

<script>
  // Inline arrow sort for /book table. Click cycles: none -> desc -> asc -> none.
  // Re-binds on every astro:page-load so it survives ClientRouter navigations.
  document.addEventListener("astro:page-load", () => {
    const table = document.querySelector<HTMLTableElement>("table")
    if (!table) return
    const tbody = table.tBodies[0]
    if (!tbody) return

    const headers = table.querySelectorAll<HTMLElement>("th[data-sort-col]")
    if (!headers.length) return

    // Remember the original DOM order so we can restore "no sort" state.
    const original = Array.from(tbody.children) as HTMLTableRowElement[]

    let activeCol: string | null = null
    let activeDir: "asc" | "desc" | null = null

    const render = () => {
      // Restore original first, then apply sort if active.
      let rows: HTMLTableRowElement[]
      if (activeCol === null) {
        rows = original.slice()
      } else {
        const col = activeCol
        const dir = activeDir
        rows = original.slice().sort((a, b) => {
          const av = Number(a.dataset[col] ?? 0)
          const bv = Number(b.dataset[col] ?? 0)
          return dir === "asc" ? av - bv : bv - av
        })
      }
      const frag = document.createDocumentFragment()
      rows.forEach((r) => frag.appendChild(r))
      tbody.appendChild(frag)

      // Update each header label to show the active arrow.
      headers.forEach((h) => {
        const label = h.dataset.sortLabel ?? ""
        const labelEl = h.querySelector<HTMLElement>(".sort-label")
        if (!labelEl) return
        if (h.dataset.sortCol === activeCol) {
          const arrow = activeDir === "desc" ? "↓" : "↑"
          labelEl.textContent = `${label} ${arrow}`
        } else {
          labelEl.textContent = label
        }
      })
    }

    headers.forEach((h) => {
      h.addEventListener("click", () => {
        const col = h.dataset.sortCol
        if (!col) return
        if (activeCol !== col) {
          activeCol = col
          activeDir = "desc"
        } else if (activeDir === "desc") {
          activeDir = "asc"
        } else {
          activeCol = null
          activeDir = null
        }
        render()
      })
    })
  })
</script>
